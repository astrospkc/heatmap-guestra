      "seed": 1333935434,
      "version": 39,
      "versionNonce": 1575242646,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1778222550664,
      "link": null,
      "locked": false,
      "text": "useCallback alone does\nnothing without React.memo\non the child component. They\nwork as a pair — useCallback\nstabilizes the reference,\nReact.memo skips re-renders\nwhen props are stable.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "useCallback alone does nothing without React.memo on the child component. They work as a pair — useCallback stabilizes the reference, React.memo skips re-renders when props are stable.",
      "autoResize": false,
      "lineHeight": 1.25
    },
