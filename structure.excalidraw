      "updated": 1778222496999,
      "link": null,
      "locked": false,
      "text": "User moves mouse → mouseenter fires on cell 5\n  → setDragEnd(date) called  ← state update\n  → CalendarGrid re-renders\n  → handleMouseEnter is a NEW function (no useCallback)\n  → ALL 30 cell components receive this new function as prop\n  → ALL 30 cells re-render (even cells 1-4 and 6-30 that weren't touched)",
      "fontSize": 14.732123963752478,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User moves mouse → mouseenter fires on cell 5\n  → setDragEnd(date) called  ← state update\n  → CalendarGrid re-renders\n  → handleMouseEnter is a NEW function (no useCallback)\n  → ALL 30 cell components receive this new function as prop\n  → ALL 30 cells re-render (even cells 1-4 and 6-30 that weren't touched)",
      "autoResize": true,
      "lineHeight": 1.25
    },
